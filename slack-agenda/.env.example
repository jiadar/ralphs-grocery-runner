# Slack user OAuth token — needs these scopes:
#   channels:history, channels:read
#   groups:history, groups:read
#   im:history, im:read
#   mpim:history, mpim:read
#   users:read, users:read.email
#   search:read (optional, for channel search)
# This should be a *user* token (xoxp-...), not a bot token,
# so it can access DMs and conversations your users are in.
SLACK_USER_TOKEN=xoxp-your-token-here

# Anthropic API key for agenda generation
ANTHROPIC_API_KEY=sk-ant-your-key-here
